    set-headers-on-request: false
  - name: jetty
    property-id: jetty.home
    set-headers-on-request: false
  - name: tomcat
    property-id: catalina.base
    set-headers-on-request: false
  - name: websphere
    property-id: was.install.root
    set-headers-on-request: true






