agent-misc-settings:
  sslProtocol: TLSV1.2
  version: 24.10.0-1295


agent-logging:
  initialMaxLogSize: 2000000
  maxLogSize: 1000000
  maxLogs: 10
  maxLogBackups: 5
  maxLogMsgsPerSecond: 100
  maxLoggingQueueSize: 1000
  showDecryptedFiles: true
  useLocking: false
